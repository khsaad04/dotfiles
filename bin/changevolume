#!/usr/bin/env bash

set -e

icon_path="$(dirname "$0")/icons"
amount=${2:-5}
notif_id="80085"
timeout=2000 # in miliseconds

is_output_muted=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | tr -dc '[]')

function notification_bar {
    notify-send -u low -r "$id" -a "$header" -i "$icon" -h int:value:"$volume" "$text" -t $timeout
}

function notification_muted {
    notify-send "$text" -u low -r $id -a "$header" -i "$icon" -t $timeout
}

case $1 in
up)
    wpctl set-volume @DEFAULT_AUDIO_SINK@ "$amount"%+
    volume=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | tr -dc '0-9' | sed 's/^0\{1,2\}//')
    header="Volume"
    text="Currently at $volume%"
    icon="$icon_path/vol-up.png"
    id=$notif_id
    notification_bar;;
down)
    wpctl set-volume @DEFAULT_AUDIO_SINK@ "$amount"%-
    volume=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | tr -dc '0-9' | sed 's/^0\{1,2\}//')
    header="Volume"
    text="Currently at $volume%"
    icon="$icon_path/vol-down.png"
    id=$notif_id
    notification_bar;;
mute)
    echo "$is_output_muted"
    if [ "$is_output_muted" == "[]" ]; then
        header="Volume"
        text="Unmuted."
        icon="$icon_path/vol.png"
        id=$notif_id
        wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
        notification_muted
    else
        header="Volume"
        text="Muted."
        icon="$icon_path/vol-muted.png"
        id=$notif_id
        wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
        notification_muted
    fi;;
esac
