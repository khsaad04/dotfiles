#!/usr/bin/env bash

set -e

case $1 in
drun)
    j4-dmenu-desktop --no-generic --term "foot" --dmenu='wmenu -bi -f "Iosevka 10" -N 1b211e -n dee4df -M 1b211e -m dee4df -S 8bd6b6 -s 003828'
    ;;
run)
    wmenu-run -bi -f "Iosevka 10" -N 1b211e -n dee4df -M 1b211e -m dee4df -S 8bd6b6 -s 003828
    ;;
*)
    wmenu -bi -f "Iosevka 10" -N 1b211e -n dee4df -M 1b211e -m dee4df -S 8bd6b6 -s 003828
    ;;
esac
